# Set to "true" only for local dev (tinacms dev). Must be "false" in production.
TINA_PUBLIC_IS_LOCAL=false

# GitHub repo that holds the content (blessing-marketing-od-site)
GITHUB_OWNER=alexander-blessingmarketing
GITHUB_REPO=blessing-marketing-od-site
GITHUB_BRANCH=main

# GitHub PAT with Contents:write on the repo above (needed for content + media write-back)
GITHUB_PERSONAL_ACCESS_TOKEN=

# Content location inside the site repo (per client). CONTENT_PATH = the single-doc
# collection path; CONTENT_PUBLIC_FOLDER = its parent (holds the assets/ folder).
CONTENT_PATH=src/clients/blessing-marketing-od/content
CONTENT_PUBLIC_FOLDER=src/clients/blessing-marketing-od

# MongoDB connection + per-client datalayer namespace (one shared mongo, dbName per client)
MONGODB_URI=mongodb://mongo:27017/
MONGO_DB=tina_blessing-marketing-od

# Used by NextAuth.js to encrypt JWT/session cookies — generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# Decoupled auth (lib/env-auth.ts): two admins verified against pbkdf2 hashes.
# Generate each hash with:  node scripts/gen-password-hash.mjs "<password>"
# Paste the full 1088-char hex output (no line breaks). Do NOT store plaintext here.
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=
AGENCY_ADMIN_USER=
AGENCY_ADMIN_PASSWORD_HASH=
